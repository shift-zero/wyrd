# wyrd — gitignore
# Generated worlds and exports (gitignored — these are outputs, not source)
output/
*.html
*.svg
# Generated world, sim, and character files
*sim.json*
*.ttrpg.json

# Python
__pycache__/
*.pyc
*.pyo
.venv/
*.egg-info/
dist/
build/

# OS
.DS_Store
Thumbs.db

# Temp
_check_*
_profile_*
_test_*.py
_test_*.json.gz
/uv.lock
# Auto-generated session notes
.hermes/last_session.md
.hermes/next_prompt.md
.cron-context.md
wyrd-*.json

# Character saves
saves/

# Debug / scratch scripts
check_*.py
fix_*.py
patch_*.py
verify_*.py
_debug_*.py
